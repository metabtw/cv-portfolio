# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# [Database]
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# [NextAuth]
# You can generate a new secret via: openssl rand -base64 32
NEXTAUTH_SECRET="your_generated_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# [Admin Credentials]
# Used to sign into the /admin panel
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="your_secure_password"

# [GitHub Integration]
# Used for syncing your repositories
GITHUB_USERNAME="your_github_username"
GITHUB_TOKEN="your_github_personal_access_token"

# [LinkedIn Integration] (Optional for future)
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
